{
  "enabledMcpjsonServers": ["fullstack-guidelines"],
  "permissions": {
    "allow": [
      "mcp__fullstack-guidelines__get_metadata",
      "mcp__fullstack-guidelines__get_guideline",
      "mcp__fullstack-guidelines__search_guidelines",
      "Bash(validate-tools *)",
      "Bash(python .claude/hooks/run-hook.py *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/reinject-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/guard-bash.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/guard-commit.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/guard-edits.sh"
          }
        ]
      },
      {
        "matcher": "mcp__fullstack-guidelines__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/guard-mcp.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "backend-developer|frontend-developer",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/verify-subagent.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/notify-attention.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/format-changed.sh"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/run-hook.py .claude/hooks/notify-stop.sh"
          }
        ]
      }
    ]
  }
}
