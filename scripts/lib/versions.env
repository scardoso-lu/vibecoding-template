# Pinned toolchain versions — the single source of truth for both bootstrap scripts.
#
# Why pin? An exact version + a verified hash means every vibecoder installs the
# byte-for-byte same toolchain. Bump these deliberately, then refresh
# scripts/lib/checksums.txt for anything downloaded directly (see scripts/README.md).
#
# Format: KEY=value  (no spaces, no quotes — parsed by both bash and PowerShell)

# Python interpreter (managed by uv: `uv python install`)
PYTHON_VERSION=3.12.7

# Node.js LTS line. macOS installs node@<major> via Homebrew; Windows pins this
# exact version via winget. The patch number is authoritative for Windows.
NODE_VERSION=22.11.0

# uv — Python package manager + Python installer. The official installer verifies
# the downloaded binary's checksum itself; we additionally pin the version.
UV_VERSION=0.5.11

# pnpm — managed by Corepack, pinned via the repo's package.json "packageManager"
# field once it exists. Listed here for the bootstrap to enable Corepack.
PNPM_VERSION=10.16.0

# Playwright browser channel to install (chromium pulls the libs we need too).
PLAYWRIGHT_BROWSER=chromium

# --- Supply-chain cooldown -------------------------------------------------
# Reject any package version published less than this many days ago. Defends
# against freshly-published malicious releases (the typical npm/PyPI attack).
DEPENDENCY_COOLDOWN_DAYS=14
